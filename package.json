{
  "name": "training-manager",
  "version": "1.0.0",
  "description": "SaaS-ready hybrid training manager for athletes",
  "main": "index.js",
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "dev:init": "rw-scripts dev-init",
    "preview": "vite preview",
    "worker:run": "rw-scripts worker-run",
    "clean": "npm run clean:vite",
    "clean:vite": "rm -rf ./node_modules/.vite",
    "release": "rw-scripts ensure-deploy-env && npm run clean && npm run build && wrangler deploy",
    "generate": "rw-scripts ensure-env && wrangler types --include-runtime false",
    "check": "npm run generate && npm run types",
    "types": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "INTEGRATION_TEST=true vitest run tests/integration",
    "seed": "rwsdk worker-run ./src/scripts/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.47",
    "@ai-sdk/react": "3.0.136",
    "@base-ui/react": "^1.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@nkzw/fate": "^0.1.3",
    "@tailwindcss/vite": "^4.2.0",
    "@trpc/server": "^11.10.0",
    "agents": "^0.7.9",
    "ai": "6.0.134",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "kysely": "^0.28.11",
    "kysely-d1": "^0.4.0",
    "lucide-react": "^0.575.0",
    "next-themes": "^0.4.6",
    "openai": "^6.32.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-fate": "^0.1.3",
    "react-hook-form": "^7.71.2",
    "react-server-dom-webpack": "19.2.4",
    "recharts": "2.15.4",
    "rwsdk": "1.0.0-beta.54",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "workers-ai-provider": "^3.1.5",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.25.1",
    "@cloudflare/vitest-pool-workers": "^0.12.14",
    "@cloudflare/workers-types": "4.20260219.0",
    "@types/node": "~24.10.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/expect": "3.2.4",
    "@vitest/runner": "3.2.4",
    "@vitest/snapshot": "3.2.4",
    "@vitest/spy": "3.2.4",
    "@vitest/utils": "3.2.4",
    "rwsdk-community": "^0.1.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "3.2.4",
    "wrangler": "4.66.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
